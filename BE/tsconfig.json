{
  "compilerOptions": {
    // File layout - uncomment and adjust if your code is in src/
    "rootDir": "./", // or "./src" if you have src/ folder
    "outDir": "./dist",

    // Classic Node.js settings - safe & simple for Express
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "es2020",

    // Node.js types - critical
    "types": ["node"],
    "lib": ["es2020"], // esnext is fine too, but es2020 is more conservative

    // Output
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Strictness - keep what you like
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Reliability & interop
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "moduleDetection": "force",

    // MUST be false for Render / production build
    "noEmit": false

    // Remove these - they cause conflicts:
    // "allowImportingTsExtensions": true,
    // "jsx": "react-jsx" (not needed in backend)
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
